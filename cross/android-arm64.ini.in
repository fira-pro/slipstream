# Meson cross-compilation file for Android arm64 (AArch64) using the Android NDK.
#
# NDK_BIN and OPENSSL_ANDROID_PREFIX are substituted by the CI workflow using sed
# before this file is passed to `meson setup --cross-file`.
#
# Placeholders (replaced by workflow):
#   @@NDK_BIN@@          - absolute path to the NDK prebuilt LLVM bin dir
#   @@OPENSSL_PREFIX@@   - absolute path to the cross-compiled OpenSSL installation

[binaries]
c       = '@@NDK_BIN@@/aarch64-linux-android34-clang'
cpp     = '@@NDK_BIN@@/aarch64-linux-android34-clang++'
ar      = '@@NDK_BIN@@/llvm-ar'
strip   = '@@NDK_BIN@@/llvm-strip'
# pkg-config must be the HOST (x86-64) binary, not an Android one
pkg-config = 'pkg-config'

[built-in options]
# Pass OpenSSL headers and libs so that picoquic's CMake can find them.
# We use the compiler flags route because there is no Android pkg-config database.
c_args       = ['-I@@OPENSSL_PREFIX@@/include']
cpp_args     = ['-I@@OPENSSL_PREFIX@@/include']
c_link_args  = ['-L@@OPENSSL_PREFIX@@/lib', '-L@@OPENSSL_PREFIX@@/lib64']
cpp_link_args = ['-L@@OPENSSL_PREFIX@@/lib', '-L@@OPENSSL_PREFIX@@/lib64']

[host_machine]
system     = 'android'
cpu_family = 'aarch64'
cpu        = 'aarch64'
endian     = 'little'
